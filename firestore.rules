rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function householdPath(householdId) {
      return /databases/$(database)/documents/households/$(householdId);
    }

    function householdExists(householdId) {
      return exists(householdPath(householdId));
    }

    function isHouseholdOwner(householdId) {
      return isSignedIn() && householdId == 'hh_' + request.auth.uid;
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() && (isHouseholdOwner(householdId) || isMember(householdId));
    }

    function isMember(householdId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    match /households/{householdId} {
      allow create: if isHouseholdOwner(householdId) &&
        request.resource.data.createdBy == request.auth.uid;
      allow read, update, delete: if isHouseholdMember(householdId);

      match /members/{uid} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdOwner(householdId) ||
          (isSignedIn() &&
            request.auth.uid == uid &&
            isMember(householdId));
        allow update, delete: if isMember(householdId) && request.auth.uid == uid;
      }

      match /cats/{catId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /catalog/{itemId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /dailyPlans/{dailyPlanId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /events/{eventId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }
  }
}
