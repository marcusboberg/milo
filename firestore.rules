rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSharedHousehold(householdId) {
      return householdId == 'hh_milo';
    }

    match /households/{householdId} {
      allow create: if isSignedIn() && isSharedHousehold(householdId);
      allow read, update, delete: if isSignedIn() && isSharedHousehold(householdId);

      match /members/{uid} {
        allow read: if isSignedIn() && isSharedHousehold(householdId);
        allow create: if isSignedIn() &&
          isSharedHousehold(householdId) &&
          request.auth.uid == uid;
        allow update, delete: if isSignedIn() &&
          isSharedHousehold(householdId) &&
          request.auth.uid == uid;
      }

      match /cats/{catId} {
        allow read, write: if isSignedIn() && isSharedHousehold(householdId);
      }

      match /catalog/{itemId} {
        allow read, write: if isSignedIn() && isSharedHousehold(householdId);
      }

      match /dailyPlans/{dailyPlanId} {
        allow read, write: if isSignedIn() && isSharedHousehold(householdId);
      }

      match /events/{eventId} {
        allow read, write: if isSignedIn() && isSharedHousehold(householdId);
      }
    }
  }
}
