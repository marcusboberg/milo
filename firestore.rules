rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function householdPath(householdId) {
      return /databases/$(database)/documents/households/$(householdId);
    }

    function householdExists(householdId) {
      return exists(householdPath(householdId));
    }

    function isHouseholdOwner(householdId) {
      return isSignedIn() && householdId == 'hh_' + request.auth.uid;
    }

    function isHouseholdCreator(householdId) {
      return isSignedIn() &&
        householdExists(householdId) &&
        get(householdPath(householdId)).data.createdBy == request.auth.uid;
    }

    function isHouseholdMemberOrOwner(householdId) {
      return isMember(householdId) || isHouseholdOwner(householdId) || isHouseholdCreator(householdId);
    }

    function isMember(householdId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    match /households/{householdId} {
      allow create: if isHouseholdOwner(householdId) &&
        request.resource.data.createdBy == request.auth.uid;
      allow read, update, delete: if isHouseholdMemberOrOwner(householdId);

      match /members/{uid} {
        allow read: if isMember(householdId);
        allow create: if isSignedIn() &&
          request.auth.uid == uid &&
          (isMember(householdId) || isHouseholdCreator(householdId));
        allow update, delete: if isMember(householdId) && request.auth.uid == uid;
      }

      match /cats/{catId} {
        allow read, write: if isHouseholdMemberOrOwner(householdId);
      }

      match /catalog/{itemId} {
        allow read, write: if isHouseholdMemberOrOwner(householdId);
      }

      match /dailyPlans/{dailyPlanId} {
        allow read, write: if isHouseholdMemberOrOwner(householdId);
      }

      match /events/{eventId} {
        allow read, write: if isHouseholdMemberOrOwner(householdId);
      }
    }
  }
}
